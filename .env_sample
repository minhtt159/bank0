# App reads database.dsn from APP_DATABASE_DSN (env wins over config.yaml).
APP_DATABASE_DSN=postgres://admin:admin@localhost:5432/bank0?sslmode=disable

# goose (migrations)
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://admin:admin@localhost:5432/bank0?sslmode=disable
GOOSE_MIGRATION_DIR=./db/migrations
